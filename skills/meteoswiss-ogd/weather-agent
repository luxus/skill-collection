#!/usr/bin/env python3
"""
MeteoSwiss Agent Interface - For AI Agents only
Returns structured JSON for parsing and interpretation.
No human-readable output - the agent is responsible for natural language responses.

Usage: weather-agent <query>

Query types:
  - Postal code: "8001", "4001"
  - City name: "Zürich", "Bern", "Basel"  
  - Natural language: "Wetter in Zürich", "Regnet es morgen in Basel?"

Returns JSON with:
  - location: resolved location info
  - current: current weather data
  - forecast: daily forecasts
  - rain_check: simple rain analysis
  - raw: all available data
"""

import sys
import json
import re
from pathlib import Path
from datetime import datetime, timedelta

# Ensure databases exist
def ensure_databases():
    cache_dir = Path.home() / '.cache' / 'meteoswiss-ogd'
    cache_dir.mkdir(parents=True, exist_ok=True)
    
    plz_map = cache_dir / 'plz-station-map.json'
    city_map = cache_dir / 'city-plz-map.json'
    
    if not plz_map.exists() or not city_map.exists():
        # Build databases
        import subprocess
        script_dir = Path(__file__).parent
        build_script = script_dir / 'scripts' / 'build-station-plz-map.sh'
        city_script = script_dir / 'scripts' / 'build-city-plz-map.py'
        
        try:
            subprocess.run([str(build_script)], check=True, capture_output=True)
        except:
            pass
        try:
            subprocess.run(['python3', str(city_script)], check=True, capture_output=True)
        except:
            pass

def normalize_city(name):
    """Normalize city name for matching"""
    name = name.lower()
    replacements = {
        'ü': 'u', 'ä': 'a', 'ö': 'o',
        'é': 'e', 'è': 'e', 'ê': 'e',
        'à': 'a', 'á': 'a', 'â': 'a',
        'ô': 'o', 'ó': 'o', 'ò': 'o',
        'î': 'i', 'í': 'i', 'ì': 'i',
        'û': 'u', 'ú': 'u', 'ù': 'u',
        'ç': 'c', 'ñ': 'n',
        ' ': '', '-': '', '_': '', '.': '', ',': ''
    }
    for old, new in replacements.items():
        name = name.replace(old, new)
    return name

def resolve_location(query):
    """Resolve natural language query to PLZ and station"""
    query = query.strip()
    
    # Direct PLZ match
    if re.match(r'^\d{4}$', query):
        return query, None
    
    # Extract PLZ from text
    plz_match = re.search(r'\b(\d{4})\b', query)
    if plz_match:
        return plz_match.group(1), query
    
    # City name extraction
    cache_dir = Path.home() / '.cache' / 'meteoswiss-ogd'
    city_map_file = cache_dir / 'city-plz-map.json'
    
    if city_map_file.exists():
        with open(city_map_file) as f:
            data = json.load(f)
        
        # Direct match
        cities = data.get('cities', {})
        
        # Check all cities
        query_norm = normalize_city(query)
        for city, info in cities.items():
            city_norm = normalize_city(city)
            # Exact match or substring
            if city_norm in query_norm or query_norm in city_norm:
                return info['plz'], query
        
        # Check for partial matches (e.g., "Züri" for "Zürich")
        for city, info in cities.items():
            if city[:4].lower() in query.lower():
                return info['plz'], query
    
    return None, query

def get_weather_data(plz):
    """Fetch weather and forecast data for PLZ"""
    import subprocess
    import csv
    import urllib.request
    
    cache_dir = Path.home() / '.cache' / 'meteoswiss-ogd'
    
    # Get station mapping
    plz_map_file = cache_dir / 'plz-station-map.json'
    with open(plz_map_file) as f:
        plz_map = json.load(f)
    
    mapping = plz_map.get(plz, {})
    station = mapping.get('station', 'SMA')
    point_id = mapping.get('point_id', '')
    station_name = mapping.get('station_name', 'Unknown')
    
    result = {
        'query_plz': plz,
        'station': station,
        'station_name': station_name,
        'point_id': point_id,
        'timestamp': datetime.now().isoformat(),
        'current': {},
        'forecast': [],
        'rain_analysis': {}
    }
    
    # Fetch current weather
    try:
        url = 'https://data.geo.admin.ch/ch.meteoschweiz.messwerte-aktuell/VQHA80.csv'
        with urllib.request.urlopen(url, timeout=10) as response:
            content = response.read().decode('utf-8')
        
        lines = content.strip().split('\n')
        headers = lines[0].split(';')
        
        for line in lines[1:]:
            parts = line.split(';')
            if parts[0] == station:
                result['current'] = {
                    'timestamp_utc': parts[1] if len(parts) > 1 else None,
                    'temperature_c': float(parts[2]) if len(parts) > 2 and parts[2] else None,
                    'precipitation_mm': float(parts[3]) if len(parts) > 3 and parts[3] else 0,
                    'sunshine_min': float(parts[4]) if len(parts) > 4 and parts[4] else 0,
                    'global_radiation_wm2': float(parts[5]) if len(parts) > 5 and parts[5] else None,
                    'humidity_percent': float(parts[6]) if len(parts) > 6 and parts[6] else None,
                    'dew_point_c': float(parts[7]) if len(parts) > 7 and parts[7] else None,
                    'wind_direction_deg': float(parts[8]) if len(parts) > 8 and parts[8] else None,
                    'wind_speed_kmh': float(parts[9]) if len(parts) > 9 and parts[9] else None,
                    'wind_gust_kmh': float(parts[10]) if len(parts) > 10 and parts[10] else None,
                    'pressure_hpa': float(parts[11]) if len(parts) > 11 and parts[11] else None,
                }
                break
    except Exception as e:
        result['error_current'] = str(e)
    
    # Fetch forecast
    if point_id:
        try:
            today = datetime.now().strftime('%Y%m%d')
            base_url = f'https://data.geo.admin.ch/ch.meteoschweiz.ogd-local-forecasting/{today}-ch/vnut12.lssw.{today}1100'
            
            # Max temp
            max_url = f'{base_url}.tre200dx.csv'
            with urllib.request.urlopen(max_url, timeout=10) as response:
                content = response.read().decode('utf-8')
            
            max_temps = {}
            for line in content.strip().split('\n')[1:]:
                parts = line.split(';')
                if parts[0] == point_id:
                    date = parts[2]
                    max_temps[date] = float(parts[3]) if len(parts) > 3 and parts[3] else None
            
            # Min temp
            min_url = f'{base_url}.tre200dn.csv'
            with urllib.request.urlopen(min_url, timeout=10) as response:
                content = response.read().decode('utf-8')
            
            min_temps = {}
            for line in content.strip().split('\n')[1:]:
                parts = line.split(';')
                if parts[0] == point_id:
                    date = parts[2]
                    min_temps[date] = float(parts[3]) if len(parts) > 3 and parts[3] else None
            
            # Rain amount
            rain_url = f'{base_url}.rka150d0.csv'
            with urllib.request.urlopen(rain_url, timeout=10) as response:
                content = response.read().decode('utf-8')
            
            rain = {}
            for line in content.strip().split('\n')[1:]:
                parts = line.split(';')
                if parts[0] == point_id:
                    date = parts[2]
                    rain[date] = float(parts[3]) if len(parts) > 3 and parts[3] else 0
            
            # Build forecast array
            for i, (date, max_t) in enumerate(sorted(max_temps.items())[:5]):
                day_label = ['Heute', 'Morgen', 'Übermorgen', f'+{i} Tage'][min(i, 3)]
                
                forecast = {
                    'day_label': day_label,
                    'date_YYYYMMDD': date,
                    'max_temp_c': max_t,
                    'min_temp_c': min_temps.get(date),
                    'rain_mm': rain.get(date, 0),
                    'will_rain': rain.get(date, 0) > 0
                }
                result['forecast'].append(forecast)
            
        except Exception as e:
            result['error_forecast'] = str(e)
    
    # Rain analysis
    if result['forecast']:
        rainy_days = [f for f in result['forecast'] if f['will_rain']]
        total_rain = sum(f['rain_mm'] for f in result['forecast'])
        
        result['rain_analysis'] = {
            'rainy_days_count': len(rainy_days),
            'total_rain_next_5_days_mm': total_rain,
            'rain_today': result['forecast'][0]['will_rain'] if result['forecast'] else False,
            'rain_tomorrow': result['forecast'][1]['will_rain'] if len(result['forecast']) > 1 else False,
            'next_rain_day': rainy_days[0]['day_label'] if rainy_days else None,
            'next_rain_amount_mm': rainy_days[0]['rain_mm'] if rainy_days else 0
        }
    
    return result

def main():
    if len(sys.argv) < 2:
        print(json.dumps({'error': 'Usage: weather-agent <query>'}), file=sys.stderr)
        sys.exit(1)
    
    query = ' '.join(sys.argv[1:])
    
    # Ensure databases exist
    ensure_databases()
    
    # Resolve location
    plz, original_query = resolve_location(query)
    
    if not plz:
        print(json.dumps({
            'error': f'Could not resolve location: {query}',
            'suggestion': 'Try a 4-digit postal code (e.g., 8001)'
        }))
        sys.exit(1)
    
    # Get weather data
    data = get_weather_data(plz)
    data['original_query'] = original_query or query
    
    # Output JSON
    print(json.dumps(data, indent=2, ensure_ascii=False))

if __name__ == '__main__':
    main()
