#!/bin/bash
set -euo pipefail

# weather-agent - AI Agent Interface (Bash Version)
# Returns JSON for agent interpretation
# Usage: weather-agent <plz_or_city>

INPUT="${1:-}"
CACHE_DIR="${HOME}/.cache/meteoswiss-ogd"

# Check database age (rebuild if > 1 year)
needs_update() {
  local file="$1"
  if [[ ! -f "$file" ]]; then
    return 0
  fi
  local mtime=$(stat -f%m "$file" 2>/dev/null || stat -c%Y "$file" 2>/dev/null || echo 0)
  local now=$(date +%s)
  local age=$((now - mtime))
  local year=$((365 * 24 * 3600))
  [[ $age -gt $year ]]
}

# Ensure databases
if needs_update "$CACHE_DIR/plz-station-map.json" || needs_update "$CACHE_DIR/city-plz-map.json"; then
  # Build databases silently
  "$(dirname "$0")/scripts/build-station-plz-map.sh" >/dev/null 2>&1 || true
  python3 "$(dirname "$0")/scripts/build-city-plz-map.py" >/dev/null 2>&1 || true
fi

# Resolve location to PLZ
PLZ=""
if [[ "$INPUT" =~ ^[0-9]{4}$ ]]; then
  PLZ="$INPUT"
else
  # Try to resolve city name
  PLZ=$(python3 -c "
import json
import sys
query = '$INPUT'.lower().replace('ü','u').replace('ä','a').replace('ö','o')
with open('$CACHE_DIR/city-plz-map.json') as f:
    data = json.load(f)
    for city, info in data['cities'].items():
        if city.lower().replace('ü','u').replace('ä','a').replace('ö','o') == query:
            print(info['plz'])
            sys.exit(0)
" 2>/dev/null || echo "")
fi

if [[ -z "$PLZ" ]]; then
  echo '{"error": "Location not found: '$INPUT'"}'
  exit 1
fi

# Get station mapping
STATION=$(jq -r ".\"$PLZ\".station" "$CACHE_DIR/plz-station-map.json" 2>/dev/null || echo "")
STATION_NAME=$(jq -r ".\"$PLZ\".station_name" "$CACHE_DIR/plz-station-map.json" 2>/dev/null || echo "")
POINT_ID=$(jq -r ".\"$PLZ\".point_id" "$CACHE_DIR/plz-station-map.json" 2>/dev/null || echo "")

if [[ -z "$STATION" ]]; then
  echo '{"error": "No station for PLZ: '$PLZ'"}'
  exit 1
fi

# Start JSON output
echo '{'
echo "  \"query\": \"$INPUT\","
echo "  \"query_plz\": \"$PLZ\","
echo "  \"station\": \"$STATION\","
echo "  \"station_name\": \"$STATION_NAME\","
echo "  \"point_id\": \"$POINT_ID\","
echo "  \"timestamp\": \"$(date -Iseconds)\","

# Current weather
echo '  "current": {'
CURRENT=$(curl -sf "https://data.geo.admin.ch/ch.meteoschweiz.messwerte-aktuell/VQHA80.csv" 2>/dev/null | awk -F';' -v s="$STATION" 'NR==1 || $1==s' | tail -1 || echo "")
if [[ -n "$CURRENT" ]]; then
  IFS=';' read -r -a PARTS <<< "$CURRENT"
  echo "    \"timestamp_utc\": \"${PARTS[1]}\","
  echo "    \"temperature_c\": ${PARTS[2]:-null},"
  echo "    \"precipitation_mm\": ${PARTS[3]:-0},"
  echo "    \"sunshine_min\": ${PARTS[4]:-0},"
  echo "    \"global_radiation_wm2\": ${PARTS[5]:-null},"
  echo "    \"humidity_percent\": ${PARTS[6]:-null},"
  echo "    \"dew_point_c\": ${PARTS[7]:-null},"
  echo "    \"wind_direction_deg\": ${PARTS[8]:-null},"
  echo "    \"wind_speed_kmh\": ${PARTS[9]:-null},"
  echo "    \"wind_gust_kmh\": ${PARTS[10]:-null},"
  echo "    \"pressure_hpa\": ${PARTS[11]:-null}"
fi
echo '  },'

# Forecast
echo '  "forecast": ['
if [[ -n "$POINT_ID" ]]; then
  TODAY=$(date +%Y%m%d)
  BASE_URL="https://data.geo.admin.ch/ch.meteoschweiz.ogd-local-forecasting/${TODAY}-ch/vnut12.lssw.${TODAY}1100"
  
  # Get max temps
  MAX_CSV=$(curl -sf "${BASE_URL}.tre200dx.csv" 2>/dev/null | awk -F';' -v pid="$POINT_ID" '$1==pid' | head -5 || echo "")
  
  if [[ -n "$MAX_CSV" ]]; then
    DAY_NUM=0
    FIRST=true
    while IFS=';' read -r pid ptype date max_temp rest; do
      [[ -z "$pid" ]] && continue
      
      if [[ "$FIRST" == "true" ]]; then
        FIRST=false
      else
        echo ","
      fi
      
      # Day label
      if [[ $DAY_NUM -eq 0 ]]; then
        LABEL="Heute"
      elif [[ $DAY_NUM -eq 1 ]]; then
        LABEL="Morgen"
      elif [[ $DAY_NUM -eq 2 ]]; then
        LABEL="Übermorgen"
      else
        LABEL="+$DAY_NUM Tage"
      fi
      
      # Get min and rain for this date
      MIN=$(curl -sf "${BASE_URL}.tre200dn.csv" 2>/dev/null | awk -F';' -v d="$date" -v pid="$POINT_ID" '$1==pid && $3==d {print $4}' | head -1 || echo "")
      RAIN=$(curl -sf "${BASE_URL}.rka150d0.csv" 2>/dev/null | awk -F';' -v d="$date" -v pid="$POINT_ID" '$1==pid && $3==d {print $4}' | head -1 || echo "0")
      
      # Determine will_rain
      WILL_RAIN="false"
      if [[ -n "$RAIN" && "$RAIN" != "0" && "$RAIN" != "0.0" && $(echo "$RAIN > 0" | bc 2>/dev/null || echo 0) -eq 1 ]]; then
        WILL_RAIN="true"
      fi
      
      echo -n "    {"
      echo -n "\"day_label\": \"$LABEL\", "
      echo -n "\"date\": \"$date\", "
      echo -n "\"max_temp_c\": ${max_temp:-null}, "
      echo -n "\"min_temp_c\": ${MIN:-null}, "
      echo -n "\"rain_mm\": ${RAIN:-0}, "
      echo -n "\"will_rain\": $WILL_RAIN"
      echo -n "}"
      
      ((DAY_NUM++)) || true
    done <<< "$MAX_CSV"
  fi
fi
echo ''
echo '  ],'

# Rain analysis
echo '  "rain_analysis": {'
# This will be populated by the agent from forecast data
echo "    \"note\": \"Agent should analyze forecast array\""
echo '  }'

echo '}'
